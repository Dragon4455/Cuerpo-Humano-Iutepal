ue):watermark(/images/watermark_only_413.png,0,0,0):watermark(/logos/logo_url_sm.png,-10,-10,0):format(jpeg)/images/learnable/inferior-medial-genicular-artery/AhLKZTsuItaujD1ZjQ_562qwVayGa_Arteria_inferior_medialis_genus_2.png" title="Arteria inferior medial de la rodilla (Arteria inferior medialis genus); Imagen: Liene Znotina" alt="Arteria inferior medial de la rodilla (Arteria inferior medialis genus); Imagen: Liene Znotina"><img src="/thumbor/XU-7xSyQsuwKdcXZPGuqtDeyUUw=/fit-in/413x413/filters:fill(FFFFFF,true):watermark(/images/watermark_only_413.png,0,0,0):watermark(/logos/logo_url_sm.png,-10,-10,0):format(jpeg)/images/learnable/descending-genicular-artery/OiqizpNWBhDjFpIaAuClA_QTfDsWRj2z_Arteria_descendens_genus_2.png" title="Arteria descendente de la rodilla (Arteria descendens genus); Imagen: Liene Znotina" alt="Arteria descendente de la rodilla (Arteria descendens genus); Imagen: Liene Znotina"><img src="/thumbor/S0WBTyauJIC7tc_VCXJY-0QF7sY=/fit-in/413x413/filters:fill(FFFFFF,true):watermark(/images/watermark_only_413.png,0,0,0):watermark(/logos/logo_url_sm.png,-10,-10,0):format(jpeg)/images/learnable/extension-of-knee/NYHFgdghw5A5abWubEkAGg_Extension_of_knee.png" title="Extensión de la rodilla (Extensio cruris); Imagen: Paul Kim" alt="Extensión de la rodilla (Extensio cruris); Imagen: Paul Kim">
